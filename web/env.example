# Supabase Configuration
# Lấy từ: https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key (anon key)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Note: External Supabase client đã được cấu hình trong externalClient.ts
# Nếu muốn sử dụng external client, cập nhật URL và key trong file đó

