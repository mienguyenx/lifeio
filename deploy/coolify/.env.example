# LifeOS Coolify deployment environment.
# Copy to .env (or paste into Coolify's environment variables) and fill in.

# --- Images (published to GHCR by the Build & Push Images workflow) ---
IMAGE_NAMESPACE=ghcr.io/mienguyenx/lifeio
IMAGE_TAG=latest

# --- Public ports (Coolify proxies your domains to these) ---
FRONTEND_PORT=8080
BACKEND_PORT=4000

# --- Database ---
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=lifeos

# --- Backend auth secrets (generate: openssl rand -base64 48) ---
JWT_ACCESS_SECRET=change-me-access-secret-at-least-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-16-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# CORS: set to your frontend domain in production, e.g. https://life.example.com
CORS_ORIGINS=*

# --- AI gateway (default Gemini, OpenAI-compatible) ---
AI_GATEWAY_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
AI_MODEL=gemini-2.5-flash
AI_GATEWAY_API_KEY=
GEMINI_API_KEY=
LOVABLE_API_KEY=
PERPLEXITY_API_KEY=

# --- Email (optional; leave blank to disable) ---
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=LifeOS
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Frontend build-time vars (baked at IMAGE BUILD time, not here) ---
# These must be passed as --build-arg when the frontend image is built
# (the GitHub Action reads them from repo Variables/Secrets):
#   VITE_API_URL           e.g. https://api.life.example.com/api/v1
#   VITE_GOOGLE_CLIENT_ID
#   VITE_GOOGLE_API_KEY
