# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# Comma-separated list of allowed CORS origins, or * for all
CORS_ORIGINS=*

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lifeos

# Auth secrets — generate strong random values (e.g. `openssl rand -base64 48`)
JWT_ACCESS_SECRET=change-me-access-secret-at-least-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-16-chars

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- AI (Phase 3) ---
# OpenAI-compatible chat-completions gateway. Defaults to Gemini's OpenAI endpoint.
# Lovable alternative: https://ai.gateway.lovable.dev/v1/chat/completions (model google/gemini-2.5-flash)
AI_GATEWAY_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
AI_MODEL=gemini-2.5-flash
# Gateway key; if unset, falls back to GEMINI_API_KEY then LOVABLE_API_KEY.
AI_GATEWAY_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
LOVABLE_API_KEY=

# --- Email (Phase 3, send-email). Leave blank to disable (endpoint returns a clear error). ---
# Resend (preferred if set):
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=LifeOS
# SMTP fallback:
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
