# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# Comma-separated list of allowed CORS origins, or * for all
CORS_ORIGINS=*

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lifeos

# Auth secrets — generate strong random values (e.g. `openssl rand -base64 48`)
JWT_ACCESS_SECRET=change-me-access-secret-at-least-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-16-chars

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
