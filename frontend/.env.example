# LifeOS REST API base URL (the standalone backend, includes the /api/v1 prefix)
# Local dev default: http://localhost:4000/api/v1
VITE_API_URL=http://localhost:4000/api/v1

# Google integration (optional; used by Google Drive / Calendar features).
# These are public client-side values baked into the build.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
